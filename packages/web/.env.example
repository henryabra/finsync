# Privacy-friendly analytics (optional). Copy to `.env.local` for local testing,
# or set these as GitHub repository *Variables* (Settings → Secrets and variables
# → Actions → Variables) to enable on the deployed Pages site.
#
# Leave unset to disable analytics entirely (no script loaded, nothing sent).
# These are NOT secrets — the website id is public in the served page.

# Umami Cloud (recommended free tier — https://cloud.umami.is):
#   VITE_ANALYTICS_SRC=https://cloud.umami.is/script.js
#   VITE_ANALYTICS_WEBSITE_ID=<your-website-id>

# GoatCounter (free for personal/open-source — https://www.goatcounter.com):
#   VITE_ANALYTICS_SRC=https://gc.zgo.at/count.js
#   VITE_ANALYTICS_WEBSITE_ID=<your-code>   # (script also reads data-goatcounter)

# Plausible (paid cloud, or self-hosted):
#   VITE_ANALYTICS_SRC=https://plausible.io/js/script.tagged-events.js
#   VITE_ANALYTICS_DOMAIN=henryabra.github.io
